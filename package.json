{
  "name": "honggocat",
  "productName": "HongGoCat",
  "version": "1.3.2",
  "description": "HongGoCat — a full-screen bongo-cat desktop overlay that taps along with your keyboard/mouse, with multiplayer rooms and cursor-homing missiles",
  "main": "main.js",
  "author": "hrkim",
  "scripts": {
    "start": "electron .",
    "server": "node server/server.js",
    "dist": "electron-builder",
    "release": "electron-builder --publish always",
    "ship:patch": "npm version patch && git push --follow-tags",
    "ship:minor": "npm version minor && git push --follow-tags",
    "ship:major": "npm version major && git push --follow-tags"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "uiohook-napi": "^1.5.4",
    "ws": "^8.18.0"
  },
  "build": {
    "appId": "com.hrkim.honggocat",
    "productName": "HongGoCat",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "!server/**",
      "!**/*.md"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HongGoCat"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "hrkim123",
        "repo": "HongGoCat",
        "releaseType": "release"
      }
    ]
  }
}
